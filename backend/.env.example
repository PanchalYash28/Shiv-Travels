# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/shiv_travels

# JWT secret used for auth tokens
JWT_SECRET=replace_with_strong_random_secret

# Phone number (in international/numeric format) that should have admin privileges
# Example: 919824926485 (preferred) or +919824926485 (either is handled)
ADMIN_PHONE=919824926485

# Optional: Fast2SMS credentials for OTP SMS sending
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# Optional: WhatsApp Cloud API (if configured, custom requirements can be pushed to admin automatically)
# See WhatsApp Business Cloud API docs for correct values.
WHATSAPP_CLOUD_API_TOKEN=your_whatsapp_cloud_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_CLOUD_API_BASE_URL=https://graph.facebook.com/v19.0

# Optional: if you want a different WhatsApp destination for admin messages
WHATSAPP_ADMIN_PHONE=919824926485

# Optional: server port
PORT=4000

# Optional: CORS allowlist for production (comma-separated)
# Example: https://your-frontend.netlify.app,https://www.yourdomain.com
FRONTEND_ORIGINS=

